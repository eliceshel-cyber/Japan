function ExpenseModal({ expense, onClose, onSave }) {
  const [form, setForm] = useState(expense || {
    date: TRIP_START,
    category: 'Food',
    desc: '',
    amount: 0,
    notes: ''
  });

  const handleSubmit = () => {
    if (!form.desc.trim()) { alert('Description is required.'); return; }
    if (!form.amount || isNaN(Number(form.amount))) { alert('Valid amount in JPY is required.'); return; }
    onSave({ ...form, amount: Math.round(Number(form.amount)) });
  };

  return (
    <div style={styles.modalBg} onClick={onClose}>
      <div style={styles.modal} onClick={e => e.stopPropagation()}>
        <div style={styles.modalHead}>
          <h2 style={styles.modalTitle}>{expense ? 'Edit expense' : 'Add expense'}</h2>
          <button style={styles.iconBtn} onClick={onClose}><X size={16} /></button>
        </div>
        <div style={styles.formGrid}>
          <label style={styles.label}>
            Date
            <input type="date" value={form.date} min={TRIP_START} max={TRIP_END}
              onChange={e => setForm({ ...form, date: e.target.value })}
              style={styles.input} />
          </label>
          <label style={styles.label}>
            Category
            <select value={form.category} onChange={e => setForm({ ...form, category: e.target.value })} style={styles.input}>
              {Object.keys(CATEGORIES).map(c => <option key={c} value={c}>{c}</option>)}
            </select>
          </label>
          <label style={{ ...styles.label, gridColumn: '1 / -1' }}>
            Description
            <input type="text" value={form.desc} onChange={e => setForm({ ...form, desc: e.target.value })}
              placeholder="e.g. Sushi dinner, Kyoto" style={styles.input} />
          </label>
          <label style={styles.label}>
            Amount in JPY (whole group)
            <input type="number" value={form.amount} onChange={e => setForm({ ...form, amount: e.target.value })}
              placeholder="e.g. 12500" style={styles.input} />
          </label>
          <label style={styles.label}>
            Notes (optional)
            <input type="text" value={form.notes || ''} onChange={e => setForm({ ...form, notes: e.target.value })}
              placeholder="vendor, payment method, etc." style={styles.input} />
          </label>
        </div>
        <div style={styles.modalActions}>
          <button style={styles.btnSecondary} onClick={onClose}>Cancel</button>
          <button style={styles.btnPrimary} onClick={handleSubmit}>
            <Save size={14} /> {expense ? 'Save changes' : 'Add expense'}
          </button>
        </div>
      </div>
    </div>
  );
}

