export default function JapanBudgetTool() {
  const [expenses, setExpenses] = useState([]);
  const [settings, setSettings] = useState(DEFAULT_SETTINGS);
  const [loaded, setLoaded] = useState(false);
  const [view, setView] = useState('date'); // 'date' | 'category' | 'matrix'
  const [editingExpense, setEditingExpense] = useState(null);
  const [showAddModal, setShowAddModal] = useState(false);
  const [showSettings, setShowSettings] = useState(false);
  const [expandedDates, setExpandedDates] = useState(new Set());

  // ===== LOAD FROM STORAGE =====
  useEffect(() => {
    (async () => {
      try {
        const stored = await window.storage.get(STORAGE_KEY);
        if (stored && stored.value) {
          setExpenses(JSON.parse(stored.value));
        } else {
          setExpenses(DEFAULT_EXPENSES);
        }
      } catch (e) {
        setExpenses(DEFAULT_EXPENSES);
      }
      try {
        const s = await window.storage.get(SETTINGS_KEY);
        if (s && s.value) setSettings(JSON.parse(s.value));
      } catch (e) { /* default */ }
      setLoaded(true);
    })();
  }, []);

  // ===== SAVE ON CHANGE =====
  useEffect(() => {
    if (!loaded) return;
    (async () => {
      try {
        await window.storage.set(STORAGE_KEY, JSON.stringify(expenses));
      } catch (e) { console.error('save failed', e); }
    })();
  }, [expenses, loaded]);

  useEffect(() => {
    if (!loaded) return;
    (async () => {
      try { await window.storage.set(SETTINGS_KEY, JSON.stringify(settings)); }
      catch (e) { console.error('settings save failed', e); }
    })();
  }, [settings, loaded]);

  // ===== DERIVED =====
  const allDates = useMemo(() => getDateRange(TRIP_START, TRIP_END), []);

  const expensesByDate = useMemo(() => {
    const map = {};
    allDates.forEach(d => { map[d] = []; });
    expenses.forEach(e => {
      if (!map[e.date]) map[e.date] = [];
      map[e.date].push(e);
    });
    return map;
  }, [expenses, allDates]);

  const totalsByCategory = useMemo(() => {
    const t = {};
    Object.keys(CATEGORIES).forEach(c => { t[c] = 0; });
    expenses.forEach(e => {
      if (t[e.category] === undefined) t[e.category] = 0;
      t[e.category] += Number(e.amount) || 0;
    });
    return t;
  }, [expenses]);

  const totalsByDate = useMemo(() => {
    const t = {};
    Object.entries(expensesByDate).forEach(([d, arr]) => {
      t[d] = arr.reduce((s, e) => s + (Number(e.amount) || 0), 0);
    });
    return t;
  }, [expensesByDate]);

  const grandTotal = useMemo(() =>
    expenses.reduce((s, e) => s + (Number(e.amount) || 0), 0),
    [expenses]
  );

  const confirmedTotal = useMemo(() =>
    expenses.filter(e => e.source === 'confirmed').reduce((s, e) => s + (Number(e.amount) || 0), 0),
    [expenses]
  );

  const estimatedTotal = useMemo(() =>
    expenses.filter(e => e.source !== 'confirmed').reduce((s, e) => s + (Number(e.amount) || 0), 0),
    [expenses]
  );

  // ===== HANDLERS =====
  const addExpense = (exp) => {
    setExpenses(prev => [...prev, { ...exp, id: uid(), source: exp.source || 'manual' }]);
  };

  const updateExpense = (id, updates) => {
    setExpenses(prev => prev.map(e => e.id === id ? { ...e, ...updates } : e));
  };

  const deleteExpense = (id) => {
    setExpenses(prev => prev.filter(e => e.id !== id));
  };

  const resetToDefaults = () => {
    if (confirm('Reset all expenses to default itinerary estimates? Your changes and uploads will be lost.')) {
      setExpenses(DEFAULT_EXPENSES);
    }
  };

  const toggleDate = (d) => {
    setExpandedDates(prev => {
      const next = new Set(prev);
      if (next.has(d)) next.delete(d); else next.add(d);
      return next;
    });
  };

  const expandAll = () => setExpandedDates(new Set(allDates));
  const collapseAll = () => setExpandedDates(new Set());

  // ============================================================================
  // RENDER
  // ============================================================================

  if (!loaded) {
    return (
      <div style={{
        minHeight: '100vh',
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        background: '#f5f1e8',
        fontFamily: 'Manrope, sans-serif'
      }}>
        <div style={{ width: 32, height: 32, border: '3px solid #d0c8b3', borderTopColor: '#1a3a52', borderRadius: '50%', animation: 'spin 1s linear infinite' }} />
      </div>
    );
  }

  return (
    <div style={styles.root}>
      <style>{globalCss}</style>

      {/* ============ HEADER ============ */}
      <header style={styles.header}>
        <div style={styles.headerInner}>
          <div style={styles.headerLeft}>
            <div style={styles.stamp}>日本</div>
            <div>
              <h1 style={styles.title}>Japan 2026 — Budget Tracker</h1>
              <p style={styles.subtitle}>Sept 16 – Oct 7 · 5 adults · {expenses.length} line items</p>
            </div>
          </div>
          <div style={styles.headerRight}>
            <button style={styles.iconBtn} onClick={() => setShowSettings(true)} title="Settings">
              <Settings size={18} />
            </button>
          </div>
        </div>

        {/* TOTALS BAR */}
        <div style={styles.totalsBar}>
          {/* Grand total + confirmed/estimated split */}
          <div style={styles.totalsTop}>
            <div style={styles.grandTotal}>
              <div style={styles.grandLabel}>Total</div>
              <div style={styles.grandValue}>{formatMoney(grandTotal, settings.displayCurrency, settings)}</div>
              <div style={styles.grandSubValues}>
                {settings.displayCurrency !== 'JPY' && <span>{formatMoney(grandTotal, 'JPY', settings)}</span>}
                {settings.displayCurrency !== 'USD' && <span>{formatMoney(grandTotal, 'USD', settings)}</span>}
                {settings.displayCurrency !== 'ILS' && <span>{formatMoney(grandTotal, 'ILS', settings)}</span>}
                <span style={{ opacity: 0.6 }}>· {formatMoney(grandTotal / settings.partySize, settings.displayCurrency, settings)}/pax</span>
              </div>
            </div>
            <div style={styles.splitBadges}>
              <div style={styles.splitConfirmed}>
                <div style={styles.splitLabel}>✓ Confirmed</div>
                <div style={styles.splitAmount}>{formatMoney(confirmedTotal, settings.displayCurrency, settings)}</div>
              </div>
              <div style={styles.splitEstimated}>
                <div style={styles.splitLabel}>~ Estimated</div>
                <div style={styles.splitAmount}>{formatMoney(estimatedTotal, settings.displayCurrency, settings)}</div>
              </div>
            </div>
          </div>
          {/* Category pills — stacked full width on mobile */}
          <div style={styles.categoryPills}>
            {Object.entries(CATEGORIES).map(([cat, conf]) => {
              const Icon = conf.icon;
              const amt = totalsByCategory[cat] || 0;
              if (amt === 0 && cat === 'Other') return null;
              const catConfirmed = expenses
                .filter(e => e.category === cat && e.source === 'confirmed')
                .reduce((s, e) => s + Number(e.amount), 0);
              const hasEstimates = amt > catConfirmed;
              return (
                <div key={cat} style={{ ...styles.catPill, borderLeftColor: conf.hex }}>
                  <Icon size={13} style={{ color: conf.hex, flexShrink: 0 }} />
                  <span style={styles.catPillName}>{cat}</span>
                  <div style={styles.catPillRight}>
                    {catConfirmed > 0 && (
                      <span style={styles.catPillConfirmed}>{formatMoney(catConfirmed, settings.displayCurrency, settings)} ✓</span>
                    )}
                    {hasEstimates && (
                      <span style={styles.catPillEst}>{formatMoney(amt - catConfirmed, settings.displayCurrency, settings)} ~</span>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </header>

      {/* ============ CONTROLS BAR ============ */}
      <div style={styles.controls}>
        <div style={styles.viewToggle}>
          {[
            { id: 'date', label: 'By Date' },
            { id: 'category', label: 'By Category' },
          ].map(v => (
            <button
              key={v.id}
              onClick={() => setView(v.id)}
              style={{
                ...styles.viewBtn,
                ...(view === v.id ? styles.viewBtnActive : {})
              }}
            >
              {v.label}
            </button>
          ))}
        </div>

        <div style={styles.actions}>
          {view === 'date' && (
            <>
              <button style={styles.smallBtn} onClick={expandAll}>Expand all</button>
              <button style={styles.smallBtn} onClick={collapseAll}>Collapse</button>
            </>
          )}
          <button style={styles.addBtn} onClick={() => setShowAddModal(true)}>
            <Plus size={15} /> Add expense
          </button>
        </div>
      </div>

      {/* ============ MAIN VIEW ============ */}
      <main style={styles.main}>
        {view === 'date' && (
          <DateView
            allDates={allDates}
            expensesByDate={expensesByDate}
            totalsByDate={totalsByDate}
            expandedDates={expandedDates}
            toggleDate={toggleDate}
            settings={settings}
            onEdit={setEditingExpense}
            onDelete={deleteExpense}
          />
        )}
        {view === 'category' && (
          <CategoryView
            expenses={expenses}
            settings={settings}
            onEdit={setEditingExpense}
            onDelete={deleteExpense}
          />
        )}
      </main>

      {/* FOOTER */}
      <footer style={styles.footer}>
        <div>
          Estimates are starting points — replace with actuals as you book. Pre-loaded from your master itinerary (v6) and past planning chats.
        </div>
        <button style={styles.resetBtn} onClick={resetToDefaults}>
          <RefreshCw size={12} /> Reset to itinerary defaults
        </button>
      </footer>

      {/* ============ MODALS ============ */}
      {(showAddModal || editingExpense) && (
        <ExpenseModal
          expense={editingExpense}
          onClose={() => { setEditingExpense(null); setShowAddModal(false); }}
          onSave={(exp) => {
            if (editingExpense) updateExpense(editingExpense.id, exp);
            else addExpense(exp);
            setEditingExpense(null);
            setShowAddModal(false);
          }}
        />
      )}

      {showSettings && (
        <SettingsModal
          settings={settings}
          onClose={() => setShowSettings(false)}
          onSave={(s) => { setSettings(s); setShowSettings(false); }}
        />
      )}
    </div>
  );
}

