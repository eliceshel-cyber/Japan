function LineItem({ expense, settings, onEdit, onDelete, showDate }) {
  const conf = CATEGORIES[expense.category] || CATEGORIES.Other;
  const Icon = conf.icon;
  const hasBadge = expense.source === 'confirmed' || expense.source === 'uploaded' || expense.source === 'manual';
  const showMeta = hasBadge || expense.notes || showDate;
  return (
    <div style={styles.lineItem}>
      <div style={{ ...styles.lineDot, background: conf.hex }} />
      <div style={styles.lineMain}>
        <div style={styles.lineTop}>
          <Icon size={12} style={{ color: conf.hex, flexShrink: 0, marginTop: 3 }} />
          <span style={styles.lineDesc}>{expense.desc}</span>
        </div>
        {showMeta && (
          <div style={styles.lineMeta}>
            {expense.source === 'confirmed' && <span style={styles.badgeConfirmed}>confirmed</span>}
            {expense.source === 'uploaded' && <span style={styles.badgeUploaded}>uploaded</span>}
            {expense.source === 'manual' && <span style={styles.badgeManual}>manual</span>}
            {showDate && <span style={styles.lineDate}>{formatDate(expense.date)}</span>}
            {expense.notes && <span style={styles.lineNotes}>{expense.notes}</span>}
          </div>
        )}
      </div>
      <div style={styles.lineAmount}>{formatMoney(expense.amount, settings.displayCurrency, settings)}</div>
      <div style={styles.lineActions}>
        <button style={styles.iconBtnSm} onClick={() => onEdit(expense)} title="Edit"><Edit3 size={12} /></button>
        <button style={styles.iconBtnSm} onClick={() => { if (confirm('Delete this expense?')) onDelete(expense.id); }} title="Delete"><Trash2 size={12} /></button>
      </div>
    </div>
  );
}

