function DateView({ allDates, expensesByDate, totalsByDate, expandedDates, toggleDate, settings, onEdit, onDelete }) {
  return (
    <div style={styles.dateList}>
      {allDates.map(d => {
        const items = expensesByDate[d] || [];
        const total = totalsByDate[d] || 0;
        const expanded = expandedDates.has(d);
        if (items.length === 0) return (
          <div key={d} style={{ ...styles.dateCard, opacity: 0.4 }}>
            <div style={styles.dateHeader}>
              <span style={styles.dateLabel}>{formatDate(d)}</span>
              <span style={{ ...styles.dateTotal, opacity: 0.5 }}>no expenses</span>
            </div>
          </div>
        );
        return (
          <div key={d} style={styles.dateCard}>
            <button style={styles.dateHeader} onClick={() => toggleDate(d)}>
              <div style={styles.dateHeaderLeft}>
                {expanded ? <ChevronDown size={14} /> : <ChevronRight size={14} />}
                <span style={styles.dateLabel}>{formatDate(d)}</span>
                <span style={styles.dateItemCount}>{items.length} item{items.length === 1 ? '' : 's'}</span>
              </div>
              <span style={styles.dateTotal}>{formatMoney(total, settings.displayCurrency, settings)}</span>
            </button>
            {expanded && (
              <div style={styles.lineItems}>
                {items.map(e => (
                  <LineItem key={e.id} expense={e} settings={settings} onEdit={onEdit} onDelete={onDelete} />
                ))}
              </div>
            )}
          </div>
        );
      })}
    </div>
  );
}

function CategoryView({ expenses, settings, onEdit, onDelete }) {
  return (
    <div style={styles.catList}>
      {Object.entries(CATEGORIES).map(([cat, conf]) => {
        const items = expenses.filter(e => e.category === cat);
        if (items.length === 0 && cat === 'Other') return null;
        const total = items.reduce((s, e) => s + Number(e.amount), 0);
        const Icon = conf.icon;
        return (
          <div key={cat} style={{ ...styles.catCard, borderTopColor: conf.hex }}>
            <div style={styles.catCardHeader}>
              <div style={styles.catCardLeft}>
                <Icon size={20} style={{ color: conf.hex }} />
                <h3 style={styles.catCardTitle}>{cat}</h3>
                <span style={styles.catCardCount}>{items.length}</span>
              </div>
              <div style={{ ...styles.catCardTotal, color: conf.hex }}>
                {formatMoney(total, settings.displayCurrency, settings)}
              </div>
            </div>
            <div style={styles.catLineItems}>
              {items.sort((a, b) => a.date.localeCompare(b.date)).map(e => (
                <LineItem key={e.id} expense={e} settings={settings} onEdit={onEdit} onDelete={onDelete} showDate />
              ))}
            </div>
          </div>
        );
      })}
    </div>
  );
}

function MatrixView({ allDates, expenses, settings }) {
  const cats = Object.keys(CATEGORIES);
  const matrix = {};
  allDates.forEach(d => {
    matrix[d] = {};
    cats.forEach(c => { matrix[d][c] = 0; });
  });
  expenses.forEach(e => {
    if (!matrix[e.date]) matrix[e.date] = {};
    matrix[e.date][e.category] = (matrix[e.date][e.category] || 0) + Number(e.amount);
  });

  const colTotals = {};
  cats.forEach(c => {
    colTotals[c] = allDates.reduce((s, d) => s + (matrix[d][c] || 0), 0);
  });
  const grand = Object.values(colTotals).reduce((s, v) => s + v, 0);

  return (
    <div style={styles.matrixWrap}>
      <table style={styles.matrix}>
        <thead>
          <tr>
            <th style={styles.matrixCorner}>Date</th>
            {cats.map(c => {
              const conf = CATEGORIES[c];
              const Icon = conf.icon;
              return (
                <th key={c} style={{ ...styles.matrixHead, color: conf.hex }}>
                  <Icon size={14} style={{ verticalAlign: 'middle', marginRight: 4 }} />
                  {c}
                </th>
              );
            })}
            <th style={styles.matrixHeadTotal}>Day total</th>
          </tr>
        </thead>
        <tbody>
          {allDates.map(d => {
            const dayTotal = cats.reduce((s, c) => s + (matrix[d][c] || 0), 0);
            return (
              <tr key={d}>
                <td style={styles.matrixDateCell}>{formatDate(d)}</td>
                {cats.map(c => {
                  const v = matrix[d][c] || 0;
                  return (
                    <td key={c} style={{ ...styles.matrixCell, opacity: v === 0 ? 0.2 : 1 }}>
                      {v === 0 ? '—' : formatMoney(v, settings.displayCurrency, settings)}
                    </td>
                  );
                })}
                <td style={styles.matrixDayTotal}>{dayTotal === 0 ? '—' : formatMoney(dayTotal, settings.displayCurrency, settings)}</td>
              </tr>
            );
          })}
        </tbody>
        <tfoot>
          <tr>
            <td style={styles.matrixFootLabel}>Total</td>
            {cats.map(c => (
              <td key={c} style={{ ...styles.matrixFootCell, color: CATEGORIES[c].hex }}>
                {formatMoney(colTotals[c] || 0, settings.displayCurrency, settings)}
              </td>
            ))}
            <td style={styles.matrixGrand}>{formatMoney(grand, settings.displayCurrency, settings)}</td>
          </tr>
        </tfoot>
      </table>
    </div>
  );
}

